# Proje kokune .env olarak kopyalayin: copy .env.example .env
# Satir basindaki # isaretini kaldirarak kullanin.

# --- Guvenlik (uretimde zorunlu) ---
# FLASK_ENV=production
# FLASK_SECRET_KEY=uzun-rastgele-gizli-dize
# (Alternatif isim: SECRET_KEY)

# Ilk admin (veritabaninda bu kullanici yokken bir kez)
# ADMIN_USERNAME=admin
# ADMIN_INITIAL_PASSWORD=guclu-bir-sifre

# API_ORIGIN=http://127.0.0.1:5000
# API_PREFIX=/api

# DATABASE_PATH=D:\veri\harcama_masraf.db

# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# SQLSERVER_SERVER=
# SQLSERVER_DATABASE=
# SQLSERVER_DRIVER=

# --- Backend loglama ---
# LOG_DIR=logs
# LOG_LEVEL=INFO
# LOG_CONSOLE=1
# LOG_REQUEST_DETAIL=full
#   minimal   — rid, method, path, status, sure, ip, (q)
#   standard  — + User-Agent, Content-Type, Content-Length, X-Request-ID
#   full      — + Referer, Accept, yanit MIME/boyut, Cache-Control, (govde onizleme)
# LOG_SLOW_MS=2000
# LOG_REQUEST_BODY=0
#   1 ise JSON/text govdesinin kisa onizlemesi (login/register haric; buyuk isteklerde atlanir)
# LOG_HUMAN_READABLE=1
#   1: her satirda Turkce OZET + TEKNIK blogu (varsayilan). 0: yalnizca TEKNIK (log toplayicilar icin)
