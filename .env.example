# Proje kokune .env olarak kopyalayin: copy .env.example .env
# Satir basindaki # isaretini kaldirarak kullanin.

# --- Guvenlik (uretimde zorunlu) ---
# FLASK_ENV=production
# FLASK_SECRET_KEY=uzun-rastgele-gizli-dize
# (Alternatif isim: SECRET_KEY)

# Ilk admin (veritabaninda bu kullanici yokken bir kez)
# ADMIN_USERNAME=admin
# ADMIN_INITIAL_PASSWORD=guclu-bir-sifre

# API_ORIGIN=http://127.0.0.1:5000
# API_PREFIX=/api

# DATABASE_PATH=D:\veri\harcama_masraf.db

# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# SQLSERVER_SERVER=
# SQLSERVER_DATABASE=
# SQLSERVER_DRIVER=
