# docker compose --env-file .env.docker up -d --build
# Bu dosyayi .env.docker olarak kopyalayin; asla git'e eklemeyin.

# --- PostgreSQL (db servisi) ---
POSTGRES_USER=harcama
POSTGRES_PASSWORD=guclu-rastgele-sifre
POSTGRES_DB=harcama_masraf

# Backend DATABASE_URL — sifrede @ veya ozel karakter varsa URL-encode edin
# Ornek: postgresql+psycopg2://harcama:guclu-rastgele-sifre@db:5432/harcama_masraf
DATABASE_URL=postgresql+psycopg2://harcama:guclu-rastgele-sifre@db:5432/harcama_masraf

# --- Zorunlu gizli anahtarlar ---
FLASK_SECRET_KEY=uzun-rastgele-dize-flask
JWT_SECRET_KEY=farkli-uzun-rastgele-dize-jwt

# --- Opsiyonel ---
# Disaridan erisim URL'i (istemci / CORS icin dokumantasyon)
API_ORIGIN=http://localhost
API_PREFIX=/api
HTTP_PORT=80

# Ilk admin (veritabaninda yoksa; bos birakilirsa uretimde admin olusturulmaz)
# ADMIN_USERNAME=admin
# ADMIN_INITIAL_PASSWORD=ilk-kurulum-sifresi

# Gunicorn
# GUNICORN_WORKERS=4
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=120
